class Solution {
public:
    string mapWordWeights(vector<string>& words, vector<int>& weights)
    {
        string ans;
        for(int i=0; i<words.size(); i++)
        {
            int n=words[i].size();
            int sum=0;
            for(int j=0; j<n; j++)
                sum+=weights[words[i][j]-'a'];
            ans+='z'-(sum%26);
        }
        return ans;
    }
};
