class Solution
{
public:
    vector<int> separateDigits(vector<int>& nums)
    {
        vector<int>temp;
        vector<int>ans;
        for(int i=0; i<nums.size(); i++)
        {
            while(nums[i]>0)
            {
                int dig=nums[i]%10;
                temp.push_back(dig);
                nums[i]=nums[i]/10;
            }
            reverse(temp.begin(), temp.end());
            for(int j=0; j<temp.size(); j++) ans.push_back(temp[j]);
            temp.clear();
        }
        return ans;
    }
};
