class Solution
{
public:
    bool detectCapitalUse(string word)
    {
        int u=0;
        for(char ch:word)
        {
            if(isupper(ch)) u++;
        }
        if(u==word.size()) return true;
        if(u==0) return true;
        if(u==1 && isupper(word[0])) return true;
        return false;
    }
};
