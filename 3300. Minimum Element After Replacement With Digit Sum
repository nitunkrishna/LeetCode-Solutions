class Solution
{
public:
    int minElement(vector<int>& nums)
    {
        vector<int>arr;
        for(int i=0; i<nums.size(); i++)
        {
            int a=nums[i];
            int sum=0;
            while(a>0)
            {
                int digit=a%10;
                sum+=digit;;
                a=a/10;
            }
            arr.push_back(sum);
        }
        return *min_element(arr.begin(), arr.end());
    }
};
