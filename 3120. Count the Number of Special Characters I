class Solution
{
public:
    int numberOfSpecialChars(string word)
    {
        int cnt=0;
        for(char ch='a'; ch<='z'; ch++)
        {
            bool c1=word.find(ch)!=string::npos;
            bool c2=word.find(ch-32)!=string::npos;
            if(c1 && c2) cnt++;
        }
        return cnt;
    }
};
