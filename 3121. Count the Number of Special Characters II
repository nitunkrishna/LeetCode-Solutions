class Solution
{
public:
    int numberOfSpecialChars(string word)
    {
        int cnt=0;
        for(char ch='a'; ch<='z'; ch++)
        {
            int l=word.rfind(ch);
            int u=word.find(ch-32);
            bool c1=word.rfind(ch)!=string::npos;
            bool c2=word.find(ch-32)!=string::npos;
            if(c1 && c2 && l<u) cnt++;
        }
        return cnt;
    }
};
